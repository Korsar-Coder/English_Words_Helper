{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: FastAPI (Uvicorn)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "jinja": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      }
    },
    {
      "name": "Vite: Chrome Debugger",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173", // Адрес вашего фронтенда Vite
      "webRoot": "${workspaceFolder}"
    }
  ]
}
